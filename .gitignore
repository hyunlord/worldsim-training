# ComfyUI batch-generated concept art (regeneratable from configs/buildings.yaml + seeds)
# Keep: _meta.json (reproducibility reference) and _contact_sheet.html (project snapshot)
assets/sprites/concepts/**/*.png
assets/sprites/concepts/**/*.webp
assets/sprites/concepts/_archive/
assets/sprites/concepts/_contact_sheet_thumbs/

# ComfyUI batch-generated concept art — v2 (regeneratable from configs/buildings_v2.yaml + seeds)
assets/sprites/concepts_v2/**/*.png
assets/sprites/concepts_v2/**/*.webp
assets/sprites/concepts_v2/_archive/
assets/sprites/concepts_v2/_contact_sheet_thumbs/

# v3 full regeneration output (regeneratable from configs/buildings.yaml + seeds)
# Source tree for concepts_final/; Keep tracked: _meta.json, _contact_sheet.html
assets/sprites/concepts_v3/**/*.png
assets/sprites/concepts_v3/**/*.webp
assets/sprites/concepts_v3/_archive/
assets/sprites/concepts_v3/_contact_sheet_thumbs/

# Consolidated final concept art (regeneratable from configs/buildings.yaml + seeds)
# Keep tracked: _meta.json, _manifest.json, _contact_sheet.html
assets/sprites/concepts_final/**/*.png
assets/sprites/concepts_final/**/*.webp
assets/sprites/concepts_final/_archive/
assets/sprites/concepts_final/_contact_sheet_thumbs/

# ComfyUI runtime logs
tools/comfyui/*.log

# External tools (cloned repos, large binaries)
tools/llama.cpp/

